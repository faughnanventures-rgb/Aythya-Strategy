# ============================================
# AYTHYA STRATEGY - Environment Variables
# ============================================
# Copy this file to .env.local for development
# NEVER commit .env.local to version control
# ============================================

# ============================================
# STORAGE MODE
# ============================================
# Options: 'local' | 'supabase'
# - 'local': Uses localStorage (development/testing)
# - 'supabase': Uses Supabase PostgreSQL (production)
NEXT_PUBLIC_STORAGE_MODE=local

# ============================================
# AUTHENTICATION
# ============================================
# Generate with: openssl rand -base64 32
AUTH_SECRET=your-auth-secret-min-32-characters-here

# OAuth Providers (optional for development)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Auth URLs
NEXTAUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true

# ============================================
# ANTHROPIC CLAUDE API (Required)
# ============================================
# Get your API key from: https://console.anthropic.com/
# SECURITY: This is server-side only - never expose to client
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# Model configuration
CLAUDE_MODEL=claude-sonnet-4-5-20250929
CLAUDE_MAX_TOKENS=4096

# ============================================
# SUPABASE (Required for 'supabase' storage mode)
# ============================================
# Get these from: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================
# RATE LIMITING (Optional - uses Upstash Redis)
# ============================================
# Get these from: https://console.upstash.com/
# If not set, uses in-memory rate limiting
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Rate limit configuration
RATE_LIMIT_REQUESTS_PER_HOUR=10
RATE_LIMIT_REQUESTS_PER_DAY=50

# ============================================
# SECURITY
# ============================================
# Allowed origins for CORS (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000

# API request timeout (ms)
API_TIMEOUT=30000

# Maximum conversation history to store
MAX_CONVERSATION_LENGTH=100

# Require authentication in production (set to 'true' when adding NextAuth)
REQUIRE_AUTH=false

# Skip CSRF validation in development (for testing only)
SKIP_CSRF_IN_DEV=false

# ============================================
# MONITORING (Optional)
# ============================================
# Sentry DSN for error tracking
SENTRY_DSN=

# Enable debug logging
DEBUG=false

# ============================================
# DEVELOPMENT
# ============================================
# Skip auth in development (NEVER use in production)
SKIP_AUTH_IN_DEV=false

# Mock AI responses (for UI testing without API costs)
MOCK_AI_RESPONSES=false
